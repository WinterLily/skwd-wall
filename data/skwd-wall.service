[Unit]
Description=skwd-wall wallpaper selector
Documentation=https://github.com/liixini/skwd-wall
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=quickshell -p /usr/local/share/skwd-wall/daemon.qml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
